	register new shaped recipe for player head named "§2Fenrir" with lore "§r§7Ecologist Custom Craft" with nbt compound from "{SkullOwner:{Id:[I;1744107341,533022957,-1537961745,1133912695],Properties:{textures:[{Value:""eyJ0ZXh0dXJlcyI6eyJTS0lOIjp7InVybCI6Imh0dHA6Ly90ZXh0dXJlcy5taW5lY3JhZnQubmV0L3RleHR1cmUvMjhkNDA4ODQyZTc2YTVhNDU0ZGMxYzdlOWFjNWMxYThhYzNmNGFkMzRkNjk3M2I1Mjc1NDkxZGZmOGM1YzI1MSJ9fX0=""}]}}}" using bone, leather, bone, leather, rotten flesh, leather, bone, leather, and bone with id "ctf:ecologist_craft"

