on inventory click:
	if world of player is {@CTF_World_Name} or {@CTF_Nether_Name}:
		if event-slot is barrier:
			cancel event
		
every 30 seconds:
	if {ctf_game_running} is true:
		if number of players in {@CTF_Nether_Name} is not 0:
			#send "hi" to all players
			chance of 12.5%:
				#send "hello" to all players
				set {_x} to random integer between -30 and 30
				set {_z} to random integer between -30 and 30

				set {_loc} to location({_x}, 0, {_z}, {@CTF_Nether_Name} parsed as world)

				#send {_loc} to all players

				send "§6testing: " to all players in {@CTF_Nether_Name}

				loop blocks above {_loc}:
					if loop-block is air:
						if block above loop-block is air:
							if block below loop-block is not air:
								spawn blaze at location of loop-block


command /ctfshout:
	trigger:
		if {ctf_game_running} is true:
			if world of player is {@CTF_World_Name} or {@CTF_Nether_Name}:
				send "this is not implemented yet"
			else:
				send "{@CTF_Prefix} You can only use this command while in a game of CTF!"
		else:
				send "{@CTF_Prefix} You can only use this command while in a game of CTF!"

on chat:
	if {ctf_game_running} is true:
		if world of player is {@CTF_World_Name} or {@CTF_Nether_Name}:
			cancel event
			if {ctf_red_team::*} contains uuid of player:
				loop {ctf_red_team::*}:
					send "§c§lRED » §7'%message%' §c-%name of player%" to loop-value parsed as player
			else if {ctf_blue_team::*} contains uuid of player:
				loop {ctf_blue_team::*}:
					send "§9§lBLUE » §7'%message%' §9-%name of player%" to loop-value parsed as player
			else:
				loop players in {@CTF_World_Name}:
					if {ctf_red_team::*} does not contain uuid of loop-player:
						if {ctf_blue_team::*} does not contain uuid of loop-player:
							send "§8§lSPECTATOR » §7'%message%' §6-%name of player%" to loop-player	
				

on craft:
	if world of player is {@CTF_World_Name} or {@CTF_Nether_Name}:
		if event-item is banner:
			cancel event
			send "{@CTF_Prefix} You cannot craft that item in this game!"
			stop
		
		if event-item is barrier:
			cancel event
			stop

		set {_name} to name of event-item
		set {_firstline} to first element out of lore of event-item
		if {_firstline} contains "Custom Craft":
			if {_firstline} contains "Universal":
				if {_name} contains "Chest of Fate":
					set {ctf_used_fate_craft::%uuid of player%} to true
				stop

			if {ctf_used_kit_craft::%uuid of player%} is true:
				cancel event
				stop

			set {ctf_used_kit_craft::%uuid of player%} to true

			send "{@CTF_Prefix} You have now crafted your custom craft for this game."

			if {_firstline} contains "Ecologist Custom Craft":
				spawn wolf at location of player with nbt nbt compound from "{PersistenceRequired:1b,Health:40f,Attributes:[{Name:generic.max_health,Base:40}]}"
				set {_wolf} to last spawned entity
				tame {_wolf} to player
				set name of {_wolf} to "§aFenrir"
				wait 1 tick
				set cursor slot of player to air

			if {_firstline} contains "Horsetamer Custom Craft":
				spawn horse at location of player with nbt nbt compound from "{DeathLootTable:""nonexistent:nope"",PersistenceRequired:1b,Health:30f,Variant:256,CustomName:'{""text"":""Shadowfax""}',Attributes:[{Name:generic.max_health,Base:30},{Name:generic.movement_speed,Base:0.3375},{Name:horse.jump_strength,Base:1.0}],SaddleItem:{id:""minecraft:saddle"",Count:1b}}"
				set {_horse} to last spawned entity
				tame {_horse} to player
				set name of {_horse} to "§6Shadowfax"
				wait 1 tick
				set cursor slot of player to air

on inventory click:
	if world of player is {@CTF_World_Name} or {@CTF_Nether_Name}:
		if name of cursor slot of player contains "Master's Phial":
			if event-slot is water bottle:
				send "hi" to player
				cancel event
				play sound "minecraft:block.brewing_stand.brew" to player
				remove 1 glass bottle from cursor slot of player
				give player event-item

on place of banner:
	if world of player is {@CTF_World_Name}:
		set {ctf_disallowed_biomes::*} to "minecraft:lukewarm_ocean" and "minecraft:warm_ocean"
		if not contains({ctf_disallowed_biomes::*}, biome at event-location):
			if uuid of player is {ctf_blue_team_captain}:
				if event-block is blue banner:
					set {ctf_blue_flag_pos} to event-location
					set {ctf_blue_flag_placed} to true
					loop all players:
						if {ctf_blue_team::*} contains uuid of loop-player:
							send "{@CTF_Prefix} Your team's flag has been placed at §6x: %x coordinate of {ctf_blue_flag_pos}%§6, y: %y coordinate of {ctf_blue_flag_pos}%§6, z: %z coordinate of {ctf_blue_flag_pos}%§7!" to loop-player
						else if {ctf_red_team::*} contains uuid of loop-player:
							send "{@CTF_Prefix} The other team's flag has been placed in a §6%biome at event-location%§7 biome." to loop-player
				else:
					if event-block is blue wall banner:
						send "{@CTF_Prefix} You cannot place banners on walls." to event-player
					else:
						send "{@CTF_Prefix} You can't place stolen flags!" to event-player
					cancel event
			else if uuid of player is {ctf_red_team_captain}:
				if event-block is red banner:
					set {ctf_red_flag_pos} to event-location
					set {ctf_red_flag_placed} to true
					loop all players:
						if {ctf_red_team::*} contains uuid of loop-player:
							send "{@CTF_Prefix} Your team's flag has been placed at §6x: %x coordinate of {ctf_red_flag_pos}%§6, y: %y coordinate of {ctf_red_flag_pos}%§6, z: %z coordinate of {ctf_red_flag_pos}%§7!" to loop-player
						else if {ctf_blue_team::*} contains uuid of loop-player:
							send "{@CTF_Prefix} The other team's flag has been placed in a §6%biome at event-location%§7 biome." to loop-player
				else:
					if event-block is red wall banner:
						send "{@CTF_Prefix} You cannot place banners on walls." to event-player
					else:
						send "{@CTF_Prefix} You can't place stolen flags!" to event-player
					cancel event
		else:
			send "{@CTF_Prefix} You can't place flags in oceans!" to event-player
			cancel event
	else if world of player is {@CTF_Nether_Name}:
		send "{@CTF_Prefix} You can't place flags in the nether!" to event-player
		cancel event		

on mine of netherrack:
	wait 1 tick
	chance of 3.5%:
		send "{@CTF_Prefix} Some items were buried in the netherrack!" to event-player
		play sound "entity.firework_rocket.blast" for player
		
		chance of 10%:
			drop ancient debris at event-location

		set {_items::*} to torch and coal and gold ingot and arrow and apple and nether wart and 2 nether wart and furnace and iron ingot and bottle o' enchanting and netherrack and torch and coal and gold ingot and arrow and apple and furnace and iron ingot and bottle o' enchanting and blaze powder and gunpowder and magma cream and ender pearl and netherite upgrade template
		
		chance of 30%:
			add diamond to {_items::*}
		
		loop (random integer between 5 and 8) times:
			drop random element out of {_items::*} at event-location
			remove {_slot} from {_slots::*}
		

on place of chest:
	#send "hi"
	if name of tool of player contains colored "Chest of Fate":
		#send "hihi"
		wait 2 ticks
		set {_good_items::*} to diamond and golden apple and gold ingot and 2 gold ingot and blaze rod

