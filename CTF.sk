	set {ctf_map_seeds::*} to -7425083384785797603 and -2853115369393424940 and 3465064830969400913 and 4706744060028891041 and 5143298294600212457 and -4393390708055947667 and 4446402412625611613 and -5723831693301730861 and -3104287522933369767 and -2853115369393424940 and 733823915755624381 and 5252535281280922172
	# no: 7669538021748505909
	# maybe: -39683802686620769
	# no: -559705863564020012

	clear {ctf_tips::*} 
	add "{@CTF_Prefix} §6Tip! §7Before PvP, ores have a 50%% chance to drop double items!" to {ctf_tips::*}
	add formatted "{@CTF_Prefix} §6Tip! §7You can do §6/ctfinv§7 to open a team ender chest!" to {ctf_tips::*}
	add formatted "{@CTF_Prefix} §6Tip! §7You can do §6/ctfhome§7 to be reminded of your flag's location!" to {ctf_tips::*}
	add formatted "{@CTF_Prefix} §6Tip! §7Typing §6/ctftips§7 will disable these messages!" to {ctf_tips::*}
	add formatted "{@CTF_Prefix} §6Tip! §7Using a chest, 5 rotten flesh, and a bone block, you can craft the §dChest of Fate§7, which gives various useful items!" to {ctf_tips::*}
	add formatted "{@CTF_Prefix} §6Tip! §7If you can't remember who's on your team, you can type §6/ctfteam§7!" to {ctf_tips::*}
	add formatted "{@CTF_Prefix} §6Tip! §7Mining netherrack has a chance to give you §6nice§7 items!" to {ctf_tips::*}
	add formatted "{@CTF_Prefix} §6Tip! §7Chests, furnaces, and enchanting tables you place will be locked, so only you and your teammates can access them!" to {ctf_tips::*}

	set {ctf_tip_counter} to 1


#----------------------------------------------------------
# THE LOBBY
#----------------------------------------------------------

on drop:
	if player is in {@CTF_Lobby_Name}:
		cancel event

on place:
	if player is in {@CTF_Lobby_Name}:
		if gamemode of player is not creative:
			cancel event

on hunger bar change:
	if player is in {@CTF_Lobby_Name}:
		cancel event
		set saturation of player to 20
		set food of player to 10

on inventory click:
	if player is in {@CTF_Lobby_Name}:
		if gamemode of player is not creative:
			cancel event

on mine:
	if player is in {@CTF_Lobby_Name}:
		if gamemode of player is not creative:
			cancel event

on teleport:
	wait 1 tick
	if player is in {@CTF_Lobby_Name}:
		if {ctf_selected_kit::%uuid of player%} is not set:
			set {ctf_selected_kit::%uuid of player%} to 1

		clear player's inventory
		set slot 1 of player to stone pickaxe named "§7§lToolsmith" with lore "§r§7 - 1x Stone Sword (Unbreaking and Efficiency I)" and "§r§7 - 1x Stone Pickaxe (Unbreaking and Efficiency I)" and "§r§7 - 1x Stone Axe (Unbreaking and Efficiency I)" and "§r§7 - 1x Stone Shovel (Unbreaking and Efficiency I)" and "§r§7 - 1x Stone Hoe (Unbreaking and Efficiency I)" and "" and "§r§7§lCustom Craft:" and "§r§7Philosopher's Pickaxe (Almost broken pickaxe, Fortune II)"
		set slot 2 of player to bow named "§a§lHunter" with lore "§r§a - 4x String" and "§r§a - 8x Feather" and "§r§a - 12x Stick" and "§r§a - 1x Stone Shovel (Unbreaking I, Fortune I)" and "" and "§r§a§lCustom Craft:" and "§r§aCupid's Bow (Bow, Power II and Flame, +20%% speed)"
		set slot 3 of player to redstone dust named "§c§lEngineer" with lore "§r§c - 3x Iron Ingot" and "§r§c - 24x Redstone Dust" and "§r§c§l - Spawns with any three of the following:" and "§r§c   - 2x Lever" and "§r§c   - 2x Piston" and "§r§c   - 2x Slimeball" and "§r§c   - 1x Minecraft with TNT" and "§r§c   - 1x Lava Bucket" and "" and "§r§c§lCustom Craft: §cAxe of Perun (Lightning Axe)"
		set slot 4 of player to lapis lazuli named "§9§lEnchanter" with lore "§r§9 - 1x Damaged Anvil" and "§r§9 - 1x Enchanted Book (Sharpness 1)" and "§r§9 - 1x Enchanted Book (Protection 1)" and "§r§9 - 10x Bottle o' Enchanting" and "§r§9 - 4x Obsidian" and "" and "§r§9§lCustom Craft:" and "§9Book of Thoth (Lots of enchantments)"
		set slot 5 of player to brewing stand named "§e§lNetherologist" with lore "§r§e - 12x Obsidian" and "§r§e - 1x Golden Sword (Looting 2)" and "" and "§r§e§lCustom Craft:" and "§r§eMaster's Phial (3 uses, duplicate a potion)"
		set slot 6 of player to diamond horse armor named "§6§lHorsetamer" with lore "§r§6 - 9x Leather" and "§r§6 - 7x Apple" and "§r§6 - 1x Saddle" and "§r§6 - Spawns with any one of the following:" and "§r§7    - 1x Diamond Horse Armor" and "§r§7    - 1x Saddle" and "§r§7    - 3x Golden Carrot" and "§r§7    - 1x Horse Spawn Egg" and "" and "§r§6§lCustom Craft:" and "§r§6Shadowfax (Tamed Horse with Saddle, maxed stats)"
		set slot 7 of player to vines named "§2§lEcologist" with lore "§r§2 - 16x Oak Log" and "§r§2 - 1x Wooden Axe (Efficiency 5)" and "§r§2 - 8x Sugar Cane" and "§r§2 - Spawns with any two of the following:" and "§r§7    - 3x Gunpowder" and "§r§7    - 3x Apple" and "§r§7    - 3x Bone" and "§r§7    - 4x Cow Spawn Egg" and "§r§7    - 1x Emerald"  and "§r§7    - 8x Carrot" and "§r§7    - 3x Rotten Flesh" and "" and "§r§2§lCustom Craft: §2Fenrir (Tamed Wolf)"
		set slot 8 of player to cake named "§d§lBaker" with lore "§r§d - 12x Bread" and "§r§d - 1x Golden Apple" and "§r§d - 1x Milk Bucket" and "" and "§r§d§lCustom Craft: §dAmbrosia (Enchanted Golden Apple)"

every 5 seconds in {@CTF_Lobby_Name}:
	loop all players in {@CTF_Lobby_Name}:
		if y coordinate of loop-player is less than 0:
			make loop-player execute "/ctfjoin"

on damage:
	if attacker is player:
		if tool of attacker is netherite axe:
			set {_tag} to tag "custom;IsPerun" of nbt compound of tool of attacker
			if {_tag} is 1:
				if difference between {ctf_perun_last_use::%uuid of attacker%} and now is greater than {@CTF_Perun_Cooldown}:
					strike lightning effect at location of victim
					damage victim by 3 hearts
					set {ctf_perun_last_use::%uuid of attacker%} to now
				else:
					send "§cThe Axe of Perun is on cooldown! You need to wait %difference between (difference between {ctf_perun_last_use::%uuid of attacker%} and now) and {@CTF_Perun_Cooldown}% to use it again!" to attacker

every 2 seconds:
	loop all players in {@CTF_Lobby_Name}:
		send action bar "§7You have the %name of slot {ctf_selected_kit::%uuid of loop-player%} of loop-player%§7 kit selected." to loop-player

on right click:
	if player is in {@CTF_Lobby_Name}:
		if tool of player is stone pickaxe:
			set {ctf_selected_kit::%uuid of player%} to 1

		if tool of player is bow:
			set {ctf_selected_kit::%uuid of player%} to 2

		if tool of player is redstone dust:
			set {ctf_selected_kit::%uuid of player%} to 3

		if tool of player is lapis lazuli:
			set {ctf_selected_kit::%uuid of player%} to 4

		if tool of player is brewing stand:
			set {ctf_selected_kit::%uuid of player%} to 5

		if tool of player is diamond horse armor:
			set {ctf_selected_kit::%uuid of player%} to 6

		if tool of player is vines:
			set {ctf_selected_kit::%uuid of player%} to 7
		
		if tool of player is cake:
			set {ctf_selected_kit::%uuid of player%} to 8

		send action bar "§7You have the %name of slot {ctf_selected_kit::%uuid of player%} of player%§7 kit selected." to player

every 15 seconds:
	loop all players in {@CTF_Lobby_Name}:
		if {ctf_tips_enabled::%uuid of loop-player%} is true:
			send formatted "%{ctf_tips::%{ctf_tip_counter}%}%" to loop-player
	
	add 1 to {ctf_tip_counter}

	if {ctf_tip_counter} is greater than size of {ctf_tips::*}:
		set {ctf_tip_counter} to 1


#----------------------------------------------------------
# THE GAME
#----------------------------------------------------------

# Prevent ender pearl use with flags
on shoot:
	shooter is player

	if in_ctf(shooter):
		if event-projectile is ender pearl:
			if uuid of shooter is {ctf_blue_flag_thief}:
				cancel event
				send "{@CTF_Prefix} You can't use ender pearls while carrying a flag." to shooter
			else if uuid of shooter is {ctf_red_flag_thief}:
				cancel event
				send "{@CTF_Prefix} You can't use ender pearls while carrying a flag." to shooter

# Lock certain blocks to their teams
on place:
	if in_ctf(player):
		if {@CTF_Block_Types_To_Lock} contains event-block:
			send "{@CTF_Prefix} This §6%type of event-block%§7 has been locked to your team, so only you and your teammates can access or destroy it." to player
			if on_red(player):
				add location of event-block to {ctf_red_owned_blocks::*}
			else if on_blue(player):
				add location of event-block to {ctf_blue_owned_blocks::*}

on right click:
	if in_ctf(player):
		if {@CTF_Block_Types_To_Lock} contains event-block:
			if block_is_accessible(player, location of event-block):
				stop
			else:
				play sound "entity.villager.no" to player 
				send "{@CTF_Prefix} You can't access %type of event-block%s placed by other teams!" to player
				cancel event

on mine:
	if in_ctf(player):
		if {@CTF_Block_Types_To_Lock} contains event-block:
			if block_is_accessible(player, location of event-block):
				stop
			else:
				play sound "entity.villager.no" to player 
				send "{@CTF_Prefix} You can't destroy %type of event-block%s placed by other teams!" to player
				clear drops
				cancel event
		else:
			stop

# 50% more ore drops before PvP
on mine of ore:
	if {ctf_game_running} is true:
		if world of player is {@CTF_World_Name}:
			if pvp is disabled in {@CTF_World_Name}:
				chance of 50%:
					loop drops of block:
						drop loop-item at location of event-block

on explosion:
	cancel event
	create a fake explosion at event-location
	loop exploded blocks:
		if loop-block is banner:
			continue
		else if block above loop-block is banner:
			continue
		else if loop-block is tnt:
			set loop-block to air
			spawn a primed tnt at the loop-block's location
			push last spawned entity direction from event-location to last spawned entity with force 1
		else:
			break loop-block

every 5 ticks:
	loop all players:
		#send {ctf_used_kit_craft::%uuid of loop-player%} to loop-player
		if "%type of top inventory of loop-player%" is "workbench inventory":
			set {_name} to name of slot 0 of top inventory of loop-player
			set {_firstline} to first element out of lore of slot 0 of top inventory of loop-player
			if {_firstline} contains colored "Toolsmith Custom Craft":
				if world of loop-player is not {@CTF_World_Name} or {@CTF_Nether_Name}:
					set slot 0 of top inventory of loop-player to air
				else if {ctf_selected_kit::%uuid of loop-player%} is not 1:
					set slot 0 of top inventory of loop-player to barrier named "§c§lThis item is only available to the Toolsmith kit!"
				else if {ctf_used_kit_craft::%uuid of loop-player%} is true:
					set slot 0 of top inventory of loop-player to barrier named "§c§lYou already used your kit craft!"
			else if {_firstline} contains "Hunter Custom Craft":
				if world of loop-player is not {@CTF_World_Name} or {@CTF_Nether_Name}:
					set slot 0 of top inventory of loop-player to air
				else if {ctf_selected_kit::%uuid of loop-player%} is not 2:
					set slot 0 of top inventory of loop-player to barrier named "§c§lThis item is only available to the Hunter kit!"
				else if {ctf_used_kit_craft::%uuid of loop-player%} is true:
					set slot 0 of top inventory of loop-player to barrier named "§c§lYou already used your kit craft!"
			else if {_firstline} contains "Engineer Custom Craft":
				if world of loop-player is not {@CTF_World_Name} or {@CTF_Nether_Name}:
					set slot 0 of top inventory of loop-player to air
				else if {ctf_selected_kit::%uuid of loop-player%} is not 3:
					set slot 0 of top inventory of loop-player to barrier named "§c§lThis item is only available to the Engineer kit!"
				else if {ctf_used_kit_craft::%uuid of loop-player%} is true:
					set slot 0 of top inventory of loop-player to barrier named "§c§lYou already used your kit craft!"
			else if {_firstline} contains "Enchanter Custom Craft":
				if world of loop-player is not {@CTF_World_Name} or {@CTF_Nether_Name}:
					set slot 0 of top inventory of loop-player to air
				else if {ctf_selected_kit::%uuid of loop-player%} is not 4:
					set slot 0 of top inventory of loop-player to barrier named "§c§lThis item is only available to the Enchanter kit!"
				else if {ctf_used_kit_craft::%uuid of loop-player%} is true:
					set slot 0 of top inventory of loop-player to barrier named "§c§lYou already used your kit craft!"
			else if {_firstline} contains "Alchemist Custom Craft":
				if world of loop-player is not {@CTF_World_Name} or {@CTF_Nether_Name}:
					set slot 0 of top inventory of loop-player to air
				else if {ctf_selected_kit::%uuid of loop-player%} is not 5:
					set slot 0 of top inventory of loop-player to barrier named "§c§lThis item is only available to the Alchemist kit!"
				else if {ctf_used_kit_craft::%uuid of loop-player%} is true:
					set slot 0 of top inventory of loop-player to barrier named "§c§lYou already used your kit craft!"
			else if {_firstline} contains "Horsetamer Custom Craft":
				if world of loop-player is not {@CTF_World_Name} or {@CTF_Nether_Name}:
					set slot 0 of top inventory of loop-player to air
				else if {ctf_selected_kit::%uuid of loop-player%} is not 6:
					set slot 0 of top inventory of loop-player to barrier named "§c§lThis item is only available to the Horsetamer kit!"
				else if {ctf_used_kit_craft::%uuid of loop-player%} is true:
					set slot 0 of top inventory of loop-player to barrier named "§c§lYou already used your kit craft!"
			else if {_firstline} contains "Ecologist Custom Craft":
				if world of loop-player is not {@CTF_World_Name} or {@CTF_Nether_Name}:
					set slot 0 of top inventory of loop-player to air
				else if {ctf_selected_kit::%uuid of loop-player%} is not 7:
					set slot 0 of top inventory of loop-player to barrier named "§c§lThis item is only available to the Ecologist kit!"
				else if {ctf_used_kit_craft::%uuid of loop-player%} is true:
					set slot 0 of top inventory of loop-player to barrier named "§c§lYou already used your kit craft!"
			else if {_firstline} contains "Baker Custom Craft":
				if world of loop-player is not {@CTF_World_Name} or {@CTF_Nether_Name}:
					set slot 0 of top inventory of loop-player to air
				else if {ctf_selected_kit::%uuid of loop-player%} is not 7:
					set slot 0 of top inventory of loop-player to barrier named "§c§lThis item is only available to the Baker kit!"
				else if {ctf_used_kit_craft::%uuid of loop-player%} is true:
					set slot 0 of top inventory of loop-player to barrier named "§c§lYou already used your kit craft!"
			else if {_name} contains "Chest of Fate":
				if world of loop-player is not {@CTF_World_Name} or {@CTF_Nether_Name}:
					set slot 0 of top inventory of loop-player to air
				else if {ctf_used_fate_craft::%uuid of loop-player%} is true:
					set slot 0 of top inventory of loop-player to barrier named "§c§lYou already crafted the Chest of Fate this game!"		
			else if {_name} contains "Revival Star":
				if world of loop-player is not {@CTF_World_Name} or {@CTF_Nether_Name}:
