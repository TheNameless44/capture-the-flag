#----------------------------------------------------------
# ALIASES
#----------------------------------------------------------

aliases:
	netherite upgrade template = minecraft:netherite_upgrade_smithing_template
	lapis block = minecraft:lapis_block
	tnt minecart = minecraft:tnt_minecart
	red banner = minecraft:red_banner
	blue banner = minecraft:blue_banner


#----------------------------------------------------------
# CONFIGURATION AND CONSTANTS
#----------------------------------------------------------

options:
	# Basic Configuration
	CTF_World_Name: "ctf"
	CTF_Nether_Name: "ctf_nether"
	CTF_Lobby_Name: "ctf_lobby"
	CTF_Prefix: §c§lC§f§lT§9§lF §7§l»§7
	CTF_Red_Flag: red banner named "§c§lThe All-Important Red Flag" with lore "§r§7This is the flag for your team." and "§r§7Make sure to place it, or" and "§r§lelse your team will not be able" and "§r§lto respawn!"
	CTF_Blue_Flag: blue banner named "§c§lThe All-Important Blue Flag" with lore "§r§7This is the flag for your team." and "§r§7Make sure to place it, or" and "§r§lelse your team will not be able" and "§r§lto respawn!"
	CTF_Stolen_Flag: light gray banner
	CTF_Captured_Flag: black banner

	# Game length
	CTF_Grace_Length: 20 minutes
	CTF_PvP_Length: 20 minutes
	CTF_Deathmatch_Length: 5 minutes

	# The game
	CTF_Perun_Cooldown: 5 seconds
	CTF_Block_Types_To_Lock: chest and trapped chest and furnace and enchanting table and blast furnace and smoker and anvil

	# DO NOT EDIT
	CTF_World: world({@CTF_World_Name})
	CTF_Nether: world({@CTF_Nether_Name})
	CTF_Lobby: world({@CTF_Lobby_Name})


#----------------------------------------------------------
# UTILITY FUNCTIONS
#----------------------------------------------------------

# Return true if this player is in either of the two CTF game worlds, and false otherwise.
function in_ctf(p: player) :: boolean:
	if world of {_p} is {@CTF_World} or {@CTF_Nether}:
		return true
	else:
		return true

function contains(list: objects, check: object) :: boolean:
    loop {_list::*}:
        if loop-value is {_check}:
            return true
    return false

function on_red(p: player) :: boolean:
	if {ctf_red_team::*} contains uuid of {_p}:
		return true
	else:
		return false

function on_blue(p: player) :: boolean:
	if {ctf_blue_team::*} contains uuid of {_p}:
		return true
	else:
		return false

function has_flag(p: player) :: boolean:
	if on_red({_p}):
		if {ctf_red_flag_captured} is true:
			return false
		else if {ctf_red_flag_placed} is false:
			return false
		else:
			return true
	else if on_blue({_p}):
		if {ctf_blue_flag_captured} is true:
			return false
		else if {ctf_blue_flag_placed} is false:
			return false
		else:
			return true
	else:
		return false

function flag_pos(p: player) :: location:
	if on_red({_p}):
		return {ctf_red_flag_pos}
	else if on_blue({_p}):
		return {ctf_blue_flag_pos}
	else:
		return location(0, 100, 0, {@CTF_World_Name})

function colored_name(p: player) :: string:
	if on_red({_p}):
		return "§c%name of {_p}%"
	else if on_blue({_p}):
		return "§9%name of {_p}%"
	else:
		return "§7%name of {_p}%"

function final_death(p: player):
	if on_red({_p}):
		remove uuid of {_p} from {ctf_red_team::*}

		if uuid of {_p} is {ctf_red_team_captain}:
			set {_old_captain} to {ctf_red_team_captain}

			set {ctf_red_team_captain} to random element out of {ctf_red_team::*}

			loop {ctf_red_team::*}:
				send "{@CTF_Prefix} Your team captain, §c%name of player({_old_captain})%§7 died permanently, so the captaincy has passed to %colored_name({ctf_red_team_captain} parsed as player)%" to player(loop-value) 
			
			if {ctf_red_flag_placed} is false:
				give {@CTF_Red_Flag} to player({ctf_red_team_captain}) 
				send "{@CTF_Prefix} You've been given the §cRed§7 flag! Make sure to place it!" to player({ctf_red_team_captain}) 
			
	else if on_blue({_p}):
		remove uuid of {_p} from {ctf_blue_team::*}

		if uuid of {_p} is {ctf_blue_team_captain}:
			set {_old_captain} to {ctf_blue_team_captain}

			set {ctf_blue_team_captain} to random element out of {ctf_blue_team::*}

			loop {ctf_blue_team::*}:
				send "{@CTF_Prefix} Your team captain, §9%name of player({_old_captain})%§7 died permanently, so the captaincy has passed to %colored_name({ctf_blue_team_captain} parsed as player)%" to player(loop-value) 

			if {ctf_blue_flag_placed} is false:
				give {@CTF_Blue_Flag} to player({ctf_blue_team_captain}) 
				send "{@CTF_Prefix} You've been given the §9Blue§7 flag! Make sure to place it!" to player({ctf_blue_team_captain}) 

function block_is_accessible(p: player, loc: location) :: boolean:
	if on_red({_p}):
		if {ctf_blue_owned_blocks::*} contains {_loc}:
			return false
		else:
			return true
	else if on_blue({_p}):
		if {ctf_red_owned_blocks::*} contains {_loc}:
			return false
		else:
			return true
	else:
		return true

command /testingtesting123:
	trigger:
		send on_red(player)
		send on_blue(player)
		send has_flag(player) to player
		send {ctf_respawning_players::*} to player


#----------------------------------------------------------
# LOAD
#----------------------------------------------------------

on load:
	# check if the CTF world exists, if it doesn't, create it
	if ({@CTF_World_Name} parsed as world) is not set:
		send "{@CTF_Prefix} World '§6%{@CTF_World_Name}%§7' does not exist, creating it." to console
		execute console command "/mvcreate %{@CTF_World_Name}% normal"

	# check if the CTF nether world exists, if it doesn't, create it
	if ({@CTF_Nether_Name} parsed as world) is not set:
		send "{@CTF_Prefix} World '§6%{@CTF_Nether_Name}%§7' does not exist, creating it." to console
		execute console command "/mvcreate %{@CTF_Nether_Name}% nether"

	# check if the CTF lobby world exists, if it doesn't, create it
	if ({@CTF_Lobby_Name} parsed as world) is not set:
		send "{@CTF_Prefix} World '§6%{@CTF_Lobby_Name}%§7' does not exist, creating it." to console
		execute console command "/mvcreate %{@CTF_Lobby_Name}% normal -t flat -g VoidGenerator"

	#wipe server crafting recipes
	#register new shapeless recipe for netherite ingot named "§7Expert's Seal" with lore "§r§7Toolsmith Custom Craft" using iron ingot, iron ingot, iron ingot, iron ingot, gold ingot, gold ingot, gold ingot, gold ingot and air with id "ctf:toolsmith_craft"
	register new shaped recipe for diamond pickaxe named "§7Philosopher's Pickaxe" with lore "§r§7Toolsmith Custom Craft" with nbt compound from "{Enchantments:[{id:""minecraft:fortune"",lvl:2s}],Damage:1558}" using gold nugget, lapis block, gold nugget, iron ingot, stick, iron ingot, air, stick and air with id "ctf:toolsmith_craft" 

	#set {_meat} to material choice of raw pork, raw beef, rotten flesh, raw chicken, raw rabbit
	#register new shaped recipe for player head named "§aFenrir" with lore "§r§7Hunter Custom Craft" with nbt nbt compound from "{SkullOwner:{Id:[I;1744107341,533022957,-1537961745,1133912695],Properties:{textures:[{Value:""eyJ0ZXh0dXJlcyI6eyJTS0lOIjp7InVybCI6Imh0dHA6Ly90ZXh0dXJlcy5taW5lY3JhZnQubmV0L3RleHR1cmUvMjhkNDA4ODQyZTc2YTVhNDU0ZGMxYzdlOWFjNWMxYThhYzNmNGFkMzRkNjk3M2I1Mjc1NDkxZGZmOGM1YzI1MSJ9fX0=""}]}}}" using bone, leather, bone, leather, rotten flesh, leather, bone, leather, and bone with id "ctf:hunter_craft"
	register new shaped recipe for bow named "§aCupid's Bow" with lore "§r§7Hunter Custom Craft" with nbt compound from "{Enchantments:[{id:""minecraft:flame"",lvl:1s},{id:""minecraft:power"",lvl:2s}]}" using air and clock and air and blaze powder and bow and blaze powder and air and golden apple and air with id "ctf:hunter_craft"

	register new shaped recipe for netherite axe named "§cAxe of Perun" with lore "§r§7Engineer Custom Craft" with nbt compound from "{custom:{IsPerun:1b}}" using copper block, redstone block, tnt, copper block, diamond axe, air, air, stick, and air with id "ctf:engineer_craft"

